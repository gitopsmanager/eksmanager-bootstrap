{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ProtectEKSManagerAdminRole",
      "Effect": "Deny",
      "Action": [
        "iam:DeleteRole",
        "iam:UpdateAssumeRolePolicy",
        "iam:PutRolePolicy",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:DeleteRolePolicy"
      ],
      "Resource": "arn:aws:iam::*:role/EKSManagerAdminRole",
      "Condition": {
        "StringNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/OrganizationAccountAccessRole",
            "arn:aws:iam::*:role/AWSCloudFormationStackSetExecutionRole",
            "arn:aws:iam::*:role/stacksets-exec-*"
          ]
        }
      }
    },
    {
      "Sid": "FreezeEKSManagerAgentRole",
      "Effect": "Deny",
      "Action": [
        "iam:DeleteRole",
        "iam:UpdateAssumeRolePolicy",
        "iam:PutRolePolicy",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:DeleteRolePolicy"
      ],
      "Resource": [
        "arn:aws:iam::{{SHARED_SERVICES_ACCOUNT_ID}}:role/EKSManagerAgentRole"
      ],
      "Condition": {
        "StringNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/OrganizationAccountAccessRole"
          ]
        }
      }
    },
    {
      "Sid": "ProtectEKSManagerStateBucket",
      "Effect": "Deny",
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:DeleteObjectVersion",
        "s3:PutBucketPolicy",
        "s3:DeleteBucketPolicy"
      ],
      "Resource": [
        "arn:aws:s3:::eks-manager-config-store-{{SHARED_SERVICES_ACCOUNT_ID}}",
        "arn:aws:s3:::eks-manager-config-store-{{SHARED_SERVICES_ACCOUNT_ID}}/*"
      ],
      "Condition": {
        "StringNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/OrganizationAccountAccessRole",
            "arn:aws:iam::{{SHARED_SERVICES_ACCOUNT_ID}}:role/EKSManagerDelegateUpdateAccountRegions"
          ]
        }
      }
    },
    {
      "Sid": "ProtectEKSManagerParameters",
      "Effect": "Deny",
      "Action": [
        "ssm:PutParameter",
        "ssm:DeleteParameter",
        "ssm:DeleteParameters",
        "ssm:LabelParameterVersion"
      ],
      "Resource": "arn:aws:ssm:*:*:parameter/EKSManager/*",
      "Condition": {
        "StringNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/OrganizationAccountAccessRole",
            "arn:aws:iam::{{SHARED_SERVICES_ACCOUNT_ID}}:role/EKSManagerDelegateUpdateAccountRegions"
          ]
        }
      }
    },
    {
      "Sid": "ProtectEKSManagerOperationalSecrets",
      "Effect": "Deny",
      "Action": [
        "secretsmanager:PutSecretValue",
        "secretsmanager:UpdateSecret",
        "secretsmanager:DeleteSecret",
        "secretsmanager:CreateSecret",
        "secretsmanager:RestoreSecret"
      ],
      "Resource": "arn:aws:secretsmanager:*:*:secret:/EKSManager/*",
      "Condition": {
        "StringNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::{{SHARED_SERVICES_ACCOUNT_ID}}:role/EKSManagerAgentRole",
            "arn:aws:iam::*:role/OrganizationAccountAccessRole"
          ]
        }
      }
    }
  ]
}
