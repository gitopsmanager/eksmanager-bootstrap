{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::{{SHARED_SERVICES_ACCOUNT_ID}}:root"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "ArnEquals": {
          "aws:PrincipalArn": "arn:aws:iam::{{SHARED_SERVICES_ACCOUNT_ID}}:role/EKSManagerAgentRole"
        }
      }
    }
  ]
}